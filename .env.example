# ===== ชิมลาง (CHIMLANG) — environment template =====
# copy เป็น .env แล้วเติมค่า | ห้าม commit ไฟล์ .env

# --- LLM (tiered ตาม TECH-DECISIONS D5) ---
LLM_BASE_URL=            # OpenAI-compatible endpoint
LLM_API_KEY=
LLM_MODEL_CROWD=         # model เล็ก/ถูก สำหรับ crowd agents
LLM_MODEL_ANALYST=       # model ใหญ่ สำหรับ analyst agent / report

# --- Cost guard (บังคับใช้โดย adapter layer) ---
RUN_BUDGET_USD_CAP=5     # เพดานต้นทุนต่อ 1 run ช่วงพัฒนา
DEFAULT_SEED=42          # reproducibility (NFR-07)

# --- Datastores ---
POSTGRES_URL=postgresql://chimlang:chimlang@localhost:5432/chimlang
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# --- Optional (ถ้าเลือก Zep ใน D4) ---
ZEP_API_KEY=

# --- Governance flags (ค่า default ปลอดภัย ห้ามปิดใน production) ---
PII_DETECTOR_ENABLED=true
WATERMARK_ENABLED=true
