# ===== ชิมลาง (CHIMLANG) — environment template =====
# copy เป็น .env แล้วเติมค่า | ห้าม commit ไฟล์ .env

# --- LLM (tiered ตาม TECH-DECISIONS D5) ---
LLM_BASE_URL=            # OpenAI-compatible endpoint
LLM_API_KEY=
LLM_MODEL_CROWD=         # model เล็ก/ถูก สำหรับ crowd agents
LLM_MODEL_ANALYST=       # model ใหญ่ สำหรับ analyst agent / report
LLM_MODEL_EMBEDDING=     # ว่าง = BM25 fallback; ถ้าตั้งต้องเพิ่มราคา model ด้วย (fail-closed)
LLM_EMBEDDING_DIMENSION=1536  # 1536 ใช้ HNSW; dimension อื่นใช้ exact pgvector + provenance
OTEL_EXPORTER_OTLP_ENDPOINT=  # optional เช่น http://collector:4318/v1/traces

# --- Cost guard (บังคับใช้โดย adapter layer) ---
RUN_BUDGET_USD_CAP=5     # เพดานต้นทุนต่อ 1 run ช่วงพัฒนา
DEFAULT_SEED=42          # reproducibility (NFR-07)

# --- Datastores ---
POSTGRES_URL=postgresql://chimlang:chimlang@localhost:5432/chimlang
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# --- Optional (ถ้าเลือก Zep ใน D4) ---
ZEP_API_KEY=

# --- Governance flags (ค่า default ปลอดภัย ห้ามปิดใน production) ---
PII_DETECTOR_ENABLED=true
WATERMARK_ENABLED=true

# Auth/RBAC ที่ API (GOV-06) — production ต้องเปิด
AUTH_ENABLED=false
API_KEYS=   # คีย์:ผู้ใช้:role[:verified],... role: viewer|analyst|operator|admin

# --- กุญแจหลักเข้ารหัส secret ใน DB (P6-M5, ADR-0007) ---
# จำเป็นเมื่อจะตั้ง LLM API key จากหน้าเว็บ (เก็บใน DB แบบเข้ารหัส)
# สร้างด้วย: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHIMLANG_SECRET_KEY=
# งบรวมต่อเดือน (USD) — LLM spend สะสมเกินค่านี้ = ระงับรันใหม่ (0 = ปิด)
MONTHLY_BUDGET_USD_CAP=50

# --- News Desk (P7, SIM-11) — โต๊ะข่าวกลางสำหรับ debate แบบข่าวสด ---
# รายการ RSS ข่าวไทย คั่นด้วย , (ว่าง = ไม่ดึง RSS)
NEWS_RSS_FEEDS=
# Tavily search API (optional) — ไม่มี = โหมด RSS อย่างเดียว (สมัครฟรี: tavily.com)
TAVILY_API_KEY=
